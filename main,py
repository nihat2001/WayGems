import os
from contextlib import asynccontextmanager
from fastapi import FastAPI, Depends
from fastapi.responses import StreamingResponse
from sqlalchemy.ext.asyncio import AsyncSession

from langchain_groq import ChatGroq
from langchain_core.prompts import ChatPromptTemplate
from langchain_core.output_parsers import StrOutputParser

from database import init_db, get_session
from rag_service import retrieve_similar_apps

@asynccontextmanager
async def lifespan(app: FastAPI):
    print("Initializing database tables...")
    await init_db()
    yield
    print("Shutting down application...")

app = FastAPI(title="FreewareFinder AI API", lifespan=lifespan)

llm = ChatGroq(
    api_key=os.getenv("API_KEY"),
    model="llama-3.3-70b-versatile",
    temperature=0.2,
    streaming=True
)

rag_prompt = ChatPromptTemplate.from_messages([
    ("system", (
        "You are an expert Open-Source Software Advocate. Your mission is to help users find free, "
        "open-source alternatives to commercial tools.\n\n"
        "Here is the verified local software data retrieved from our database:\n"
        "{context}\n\n"
        "Instructions:\n"
        "1. Prioritize the software provided in the local data if it answers the user's request.\n"
        "2. If the local data is insufficient, use your global knowledge to suggest alternatives.\n"
        "3. Format your response clearly using markdown with bullet points and include GitHub URLs if available."
    )),
    ("human", "What are the best free alternatives for {paid_software}?")
])

rag_chain = rag_prompt | llm | StrOutputParser()

async def response_generator(paid_software: str, db: AsyncSession):
    context = await retrieve_similar_apps(query=paid_software, db=db, limit=3)
    
    async for chunk in rag_chain.astream({"paid_software": paid_software, "context": context}):
        yield f"data: {chunk}\n\n"

@app.get("/api/search-stream")
async def search_software_stream(paid_software: str, db: AsyncSession = Depends(get_session)):
    return StreamingResponse(
        response_generator(paid_software, db), 
        media_type="text/event-stream"
    )